# ── Supabase (client) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (server / route handlers) ──────────────────────────────────────
# Service-role key — server only, NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (Mochi Plus + tips) ───────────────────────────────────────────────
# Server only. Use test-mode keys (sk_test_…) in development.
STRIPE_SECRET_KEY=
# From `stripe listen` locally, or the Dashboard webhook endpoint in prod.
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs for the Mochi Plus membership (create in Stripe Dashboard).
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=

# Optional: absolute site origin for Checkout return URLs. If unset, the billing
# routes fall back to the request's Origin header.
NEXT_PUBLIC_SITE_URL=

# ── Discord (Help & Feedback) ────────────────────────────────────────────────
# Webhook attached to a FORUM channel — each submitted request becomes a new
# forum post. Discord: channel → Edit Channel → Integrations → Webhooks.
DISCORD_SUPPORT_WEBHOOK_URL=
